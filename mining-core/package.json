{
  "name": "kaspa-mining-core",
  "version": "2.0.0",
  "description": "Kaspa Mining Pool Core - Real Implementation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "proto:generate": "protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/generated ./protos/rpc.proto"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.12",
    "@grpc/proto-loader": "^0.7.10",
    "bigint-buffer": "^1.1.5",
    "buffer": "^6.0.3",
    "crypto": "^1.0.1",
    "events": "^3.3.0",
    "long": "^5.2.3",
    "protobufjs": "^7.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "kaspa",
    "mining",
    "pool",
    "kHeavyHash",
    "blockchain",
    "cryptocurrency"
  ],
  "author": "Senior Blockchain Protocol Engineer",
  "license": "MIT"
}
