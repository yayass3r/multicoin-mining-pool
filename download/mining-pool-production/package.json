{
  "name": "mining-pool-production",
  "version": "1.0.0",
  "description": "Production-Ready Multi-Coin Mining Pool",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && npm run build:native",
    "build:native": "node-gyp rebuild",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "stratum": "node dist/stratum/index.js",
    "api": "node dist/api/index.js",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "test": "jest"
  },
  "dependencies": {
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "net": "^1.0.2",
    "uuid": "^9.0.1",
    "bigint-buffer": "^1.1.5",
    "bn.js": "^5.2.1",
    "bignumber.js": "^9.1.2",
    "node-addon-api": "^7.1.0",
    "bindings": "^1.5.0",
    "winston": "^3.11.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "node-gyp": "^10.0.1",
    "node-pre-gyp": "^0.17.0",
    "@types/ioredis": "^5.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "gypfile": true
}
